# GitHub App OAuth
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_CALLBACK_URL=http://localhost:3000/api/auth/callback

# GitHub Webhook (optional — enables instant deploys without polling)
# Set this as the secret in your GitHub repo → Settings → Webhooks
GITHUB_WEBHOOK_SECRET=

# Admin user (GitHub username) - auto-approved with admin role
ADMIN_GITHUB_LOGIN=

# Localtonet
LOCALTONET_AUTH_TOKEN=

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/togit

# App
PORT=3000
SESSION_SECRET=change_me_random_32chars
NODE_ENV=development

# CORS — set to your frontend URL in production (e.g., https://deploy.example.com)
ALLOWED_ORIGIN=*
